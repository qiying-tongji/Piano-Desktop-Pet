{
  "name": "piano-desktop-pet",
  "version": "0.1.0",
  "description": "A piano-themed AI desktop pet with gesture-controlled air piano",
  "author": "Piano Desktop Pet",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/sync-gesture-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-gesture-assets.mjs",
    "build": "tsc --noEmit && vite build",
    "predist": "node scripts/sync-gesture-assets.mjs --require-model",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "pack": "npm run build && electron-builder --dir",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@react-three/drei": "^10.0.7",
    "@react-three/fiber": "^9.1.2",
    "framer-motion": "^12.12.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tone": "^15.1.22",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.176.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
